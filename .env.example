# OpenRouter API Key (required for cloud models)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Ollama base URL (for local LLM fallback)
OLLAMA_BASE_URL=http://localhost:11434

# Default model priority (comma-separated OpenRouter model IDs)
MODEL_PRIORITY=deepseek/deepseek-chat-v3-0324,qwen/qwen-2.5-coder-32b-instruct,meta-llama/llama-3.3-70b-instruct

# Local fallback model (Ollama model name)
LOCAL_FALLBACK_MODEL=qwen2.5-coder:7b

# Memory persistence directory
MEMORY_DIR=~/.coding_agent/memory

# Max concurrent sub-agents
MAX_SUBAGENTS=3
